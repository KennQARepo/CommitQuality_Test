import java.util.Scanner;

public class Main
{
    public static int plusFive(int x){
        return x + 5;
    }
    public static void main(String[] args) {
        System.out.println("Pick any number, but choose correctly");
        Scanner scan = new Scanner(System.in);
        
        int num = scan.nextInt();
        
        System.out.println("Not quite, please try again");
        
        while(num != 0){
            num = scan.nextInt();
            if(num < 0 || num > 0){
                System.out.println((int)Math.pow(num,2));
                //Changes the input value to the "second power", plus changes type to an "Integer"
                System.out.println("Try again, please");
                continue;
                }else{
                System.out.println("Correct!");
                break;
            }
        }
        int newValue = plusFive(num);
        System.out.println("High " + newValue + " !"); 
        //Created the method (See above) to add 5 to the returning value of the "correct" input value
    }
}


